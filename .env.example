# ============================================================
# AGENT ANONMUSK — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Current Provider (ollama / openai)
LLM_PROVIDER=ollama

# API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Default LLM Model
LLM_MODEL=phi3:mini

# ===== OLLAMA SETTINGS =====
OLLAMA_BASE_URL=http://localhost:11434

# Output directory for reports and PoC scripts
OUTPUT_DIR=./output

# Scope file path (required for scans)
SCOPE_FILE=./scope.txt

# Proxy (optional — route through Burp Suite)
# HTTP_PROXY=http://127.0.0.1:8080

# Rate limiting (requests per second)
RATE_LIMIT=10

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
